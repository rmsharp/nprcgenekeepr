^\.lintr$
^pkgdown$
^pkgdown_site$
# Quarto pkgdown articles (website-only; never shipped). One pattern covers the
# .qmd articles, vignettes/articles/_quarto.yml, and any .quarto/ build cache.
^vignettes/articles$
^data-raw$
^dev$
^doc$
^Meta$
^revdep$
^tests/testthat/_snaps$
^CITATION\.cff$
^CRAN-SUBMISSION$
^test_results_summary.md
^\.\.Rcheck$
^\.positai$
^\.claude$
# Methodology framework files (tooling, not R package content).
# NOTE: every line in this file is a perl regex -- a comment with an unbalanced
# paren makes R CMD build abort. Keep the <NAME>.*\.md$ form broad so macOS sync
# dupes like SESSION_NOTES 2.md and CLAUDE copy.md stay build-ignored and never
# re-raise R CMD check's non-portable-file-names WARNING. S59 generalized S58.
^PROJECT_LEARNINGS.*\.md$
^CLAUDE.*\.md$
^SESSION_RUNNER.*\.md$
^SESSION_NOTES.*\.md$
^SAFEGUARDS.*\.md$
^BACKLOG.*\.md$
^ROADMAP.*\.md$
^CHANGELOG.*\.md$
^BOOTSTRAP.*\.md$
^CONTEXT_TEMPLATE.*\.md$
^HANDOFFS.*\.md$
^dashboard_history\.jsonl$

# Methodology tooling, audit reports, and dev notes -- not R package content,
# so they are build-ignored. Broad <NAME>.* forms also catch macOS sync dupes.
^methodology_dashboard\.py$
^dashboard\.html$
^nprcgenekeepr_notes\.txt$
^RECOMMENDED_SKILLS.*\.md$
^PED_GV_AUDIT.*
^TECH_DEBT_AUDIT.*

# Build cruft (S102, CRAN submission Phase 1). Every line here is a perl regex --
# an unbalanced paren even in a comment aborts R CMD build, so keep lines paren-free.
# The .DS_Store / .Rapp.history lines are end-anchored only (no leading ^) so they
# also catch copies in subdirs, e.g. man/.DS_Store and inst/extdata/.Rapp.history.
\.DS_Store$
\.Rapp\.history$
^inst/extdata/.*\.qmd$
^inst/extdata/README_modules\.md$
^inst/extdata/example_usage\.R$
^inst/extdata/trulyUnknownParents\.R$
^inst/extdata/submission\.txt$
^inst/_pkgdown\.yml$
